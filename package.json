{
  "name": "enhance-chatgpt",
  "version": "0.1.0",
  "description": "A native-feeling UI enhancement layer for the ChatGPT web app.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "npm run typecheck && npm run build:content && npm run build:pages && npm run verify:bundle",
    "build:content": "vite build --config vite.content.config.ts",
    "build:pages": "vite build --config vite.config.ts",
    "verify:bundle": "node scripts/verify-browser-bundle.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0"
  }
}
